{
  "name": "studyboard",
  "version": "1.0.0",
  "description": "Studyboard - infinite-canvas study app",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win nsis",
    "test": "node tests/manual-api.test.mjs"
  },
  "build": {
    "appId": "com.studyboard.app",
    "productName": "Studyboard",
    "directories": {
      "output": "dist"
    },
    "win": {
      "icon": "build/icon.png",
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ]
    },
    "files": [
      "main.js",
      "study-canvas.html",
      "icon.png",
      "package.json"
    ]
  },
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "electron": "^42.3.0",
    "electron-builder": "^26.8.1"
  }
}
